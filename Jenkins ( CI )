pipeline {
    agent any

    tools {
        jdk 'jdk17'
        maven 'maven3'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {

        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/gsharma1298/Mission.git'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Trivy Scan') {
            steps {
                sh 'trivy fs --format table -o trivyfile.html .'
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh """
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectKey=mission \
                    -Dsonar.projectName=mission \
                     -Dsonar.java.binaries=target/classes
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('package') {
            steps {
                sh 'mvn package -DskipTests'
            }
        }

       stage('Deploy to Nexus') {
    steps {
        withMaven(globalMavenSettingsConfig: 'nexus', jdk: 'jdk17',
        maven: 'maven3', traceability: true) {
         sh 'mvn deploy -DskipTests'
                }
               }
                }
        stage('build docker image') {
            steps {
                sh 'docker build -t gsharma1298/mission:01 .'
            }
        }

        stage('Trivy image Scan') {
            steps {
                sh 'trivy image --format table -o trivyfile.html gsharma1298/mission:01'
            }
        }

        stage('docker push image') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                        sh 'docker push gsharma1298/mission:01'
                    }
                }
            }
        }
        
         stage('docker run') {
            steps {
                        sh 'docker run -d -p 6000:6000 --name mission gsharma1298/mission:01'
                    }
                }
    }
}
